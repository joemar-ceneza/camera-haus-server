# Server
PORT=5000

# MongoDB connection string
DB_URL=mongodb://localhost:27017/camera-haus

# Shared admin token required for POST/PUT/DELETE routes.
# Send it from the client as: Authorization: Bearer <API_TOKEN>
# Must match the frontend's REACT_APP_API_TOKEN.
API_TOKEN=replace_with_a_long_random_secret

# Allowed browser origin(s) for CORS — comma-separated for multiple.
# Leave unset only in local development (falls back to allowing all origins).
CLIENT_URL=http://localhost:3000

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
